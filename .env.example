# LibreWRX Configuration
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults — you only need to set what you want to change.

# Public-facing URL used in the weather-maps.json metadata response.
# Set this to whatever URL clients will use to reach your instance.
LIBREWRX_PUBLIC_URL=http://localhost:8080

# Port the server listens on.
LIBREWRX_PORT=8080

# Maximum tile zoom level (0-12). Higher values allow more detail when zoomed in
# but use more memory for cached tiles. 12 is the max supported by the data source.
LIBREWRX_MAX_ZOOM=12

# How often (in seconds) to fetch new radar frames from IEM.
# IEM updates every 5 minutes (300s), so lower values won't yield new data.
LIBREWRX_FETCH_INTERVAL=300

# Number of radar frames to keep in memory. Each frame is ~63 MB (USCOMP only)
# or ~74 MB with all regions enabled.
# 12 frames = ~756-888 MB RAM, 20 frames = ~1.26-1.48 GB RAM.
# More frames = longer animation history.
LIBREWRX_MAX_FRAMES=12

# Maximum number of rendered tiles to keep in the LRU cache.
# Higher values use more memory but reduce re-rendering on repeated requests.
# At ~3 KB average per tile: 50000 = ~150 MB.
LIBREWRX_TILE_CACHE_SIZE=50000

# Gaussian blur radius for tile smoothing (when smooth=1 in the tile URL).
# Higher = softer/smoother radar appearance. 0 = disable smoothing entirely.
# Recommended: 2.0-4.0. Rain Viewer uses roughly 3.0.
LIBREWRX_SMOOTH_RADIUS=3.0

# Minimum dBZ threshold to display. Pixels below this are made transparent.
# Filters out ground clutter and weak noise. dBZ scale: 5 = very light, 20 = light rain.
# Set to -32 to disable (show everything).
LIBREWRX_NOISE_FLOOR_DBZ=5.0

# Speckle filter: minimum number of non-zero neighbors (out of 8) a pixel must
# have to be kept. Removes isolated radar artifacts and ground clutter.
# 0 = disabled, 2 = light, 3 = moderate (recommended), 4+ = aggressive.
LIBREWRX_DESPECKLE_MIN_NEIGHBORS=3

# WebP encoding quality. 100 = lossless (best quality, larger files).
# 80 = lossy (visually identical for radar, ~3-4x smaller than PNG).
# Only affects tiles requested in WebP format; PNG tiles are unaffected.
LIBREWRX_WEBP_QUALITY=100

# Radar regions to fetch. Use a group alias or comma-separated region codes.
#
# Group aliases:
#   CONUS   - Continental US only (default, lightest)
#   US      - All US regions (CONUS + Alaska, Hawaii, Puerto Rico, Guam)
#   ALL     - Every available region
#
# Individual regions (can mix with groups):
#   USCOMP  - Continental US (12200x5400 @ 0.005°, ~63 MB/frame)
#   AKCOMP  - Alaska (4000x1550 @ 0.01°, ~6 MB/frame)
#   HICOMP  - Hawaii (2000x1800 @ 0.005°, ~3.4 MB/frame)
#   PRCOMP  - Puerto Rico (1000x1000 @ 0.01°, ~1 MB/frame)
#   GUCOMP  - Guam (1000x1000 @ 0.0085°, ~1 MB/frame)
#
# Examples:
#   LIBREWRX_ENABLED_REGIONS=CONUS          (just continental US)
#   LIBREWRX_ENABLED_REGIONS=US             (all US regions)
#   LIBREWRX_ENABLED_REGIONS=CONUS,HICOMP   (continental US + Hawaii)
#   LIBREWRX_ENABLED_REGIONS=ALL            (everything)
LIBREWRX_ENABLED_REGIONS=CONUS

# Number of uvicorn worker processes. Each worker is a fully independent copy
# of LibreWRX with its own frame store, cache, and fetcher. More workers =
# better concurrency for simultaneous users, but each uses ~1.3 GB+ RAM
# (frames + tile cache). Scale workers first when handling more users.
#
# Scaling guide:
#   1       - Personal use / 1-5 users (~1.3 GB RAM)
#   2-4     - Small community / 5-50 users (~2.6-5.2 GB RAM)
#   4-8     - Medium traffic / 50-200 users (~5.2-10.4 GB RAM)
#   8+      - Large traffic / 200+ users (put nginx or a CDN in front too)
#
# Recommended: 1 worker per 2 CPU cores. For high traffic, a caching reverse
# proxy (nginx, CloudFlare) in front will help more than adding workers — tiles
# already set Cache-Control headers so any proxy can cache them automatically.
LIBREWRX_WORKERS=1

# Thread pool size for background tile cache warming. When a tile is requested,
# the warmer pre-renders that tile position for all other timestamps in the
# background so animation playback is smooth. This is a "nice to have"
# optimization — scale workers before increasing this.
# 4 is a good default; 6-8 on machines with many cores.
LIBREWRX_WARMER_THREADS=4
